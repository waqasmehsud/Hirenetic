# .env.example
# Copy to .env.local for development. Real values for staging/production live ONLY in
# Vercel's Environment Variables settings (scoped per Vercel Environment), never in git.
# See deployment.md §3 for where each variable's real value should live.

# ---------------------------------------------------------------------------
# Environment identifier — drives environment-aware behavior in lib/env.ts
# ---------------------------------------------------------------------------
NODE_ENV=development
# development | staging | production
APP_ENV=development

# ---------------------------------------------------------------------------
# Supabase — public (safe for browser bundle; still environment-specific)
# ---------------------------------------------------------------------------
# Development: from `supabase start` output (local stack)
# Staging/Production: from the corresponding Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Supabase — server-only secret. NEVER prefix with NEXT_PUBLIC_.
# Used only in lib/supabase/admin.ts contexts. Bypasses Row Level Security.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# Email API (Resend — free/developer tier). Server-only.
# ---------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com

# ---------------------------------------------------------------------------
# Rate limiting store (e.g., Upstash Redis free tier). Server-only.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# App-level config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated allow-list used by CORS config in staging/production; permissive in dev.
ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# CI-only (GitHub Actions secrets, not used at runtime — documented here for completeness)
# ---------------------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN=       # CLI access token for running migrations in CI
# SUPABASE_PROJECT_REF=        # target project ref for `supabase link`
# TEST_SUPABASE_URL=           # throwaway/test project used only during CI test runs
# TEST_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Environment-specific notes
# ---------------------------------------------------------------------------
# development: values above point at the local Supabase CLI stack; safe to commit
#              placeholder values here since nothing is real.
# staging:     set in Vercel > Project > Settings > Environment Variables > Preview,
#              pointing at the dedicated Supabase STAGING project. ALLOWED_ORIGINS
#              should list the staging domain only.
# production:  set in Vercel > Project > Settings > Environment Variables > Production,
#              pointing at the dedicated Supabase PRODUCTION project. ALLOWED_ORIGINS
#              should list the production domain only. Never reuse staging keys here.
